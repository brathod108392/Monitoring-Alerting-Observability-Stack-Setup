{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Application Metrics",
  "uid": "app-metrics-001",
  "tags": ["application", "production", "slo"],
  "timezone": "Asia/Kolkata",
  "refresh": "15s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Request Rate — req/sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by(service) (rate(http_requests_total[5m]))",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "title": "HTTP 5xx Error Rate %",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "(sum by(service) (rate(http_requests_total{status=~\"5..\"}[5m])) / sum by(service) (rate(http_requests_total[5m]))) * 100",
          "legendFormat": "{{ service }} error rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Request Latency — p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le, service) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 — {{ service }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le, service) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 — {{ service }}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le, service) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 — {{ service }}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 4,
      "title": "DB Query Latency — p95",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(le, query_type) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "{{ query_type }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Active DB Connections",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "db_connection_pool_size - db_connection_pool_available",
          "legendFormat": "Active connections",
          "refId": "A"
        },
        {
          "expr": "db_connection_pool_size",
          "legendFormat": "Pool size",
          "refId": "B"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(http_requests_total, service)",
        "multi": true,
        "includeAll": true,
        "label": "Service"
      }
    ]
  }
}
